# Dependencies
node_modules/
.DS_Store

# Build output
dist/
ads/
.vite/
*.tsbuildinfo

# Per-project derived-asset cache (converted textures/models). Lives at each
# game project's root so a flat project without node_modules still has a
# writable, self-contained cache. Regenerated on reimport/build — never committed.
.cache/

# Playwright E2E artifacts (reports/traces/screenshots) — regenerated per run
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# Generated asset manifest (regenerated by migrate-to-guids.mjs / dev scanner /
# build). Local artifact for scripts/show-refs.mjs — not consumed by the app,
# which uses the dev-server scan or dist/assets.manifest.json. Don't commit.
/assets.manifest.json

# Model thumbnails — re-snapshot editor-side after every Apply (Re-import).
# Local-only; the converter regenerates them on first open in any clone.
# The sidecar generated by migrate-to-guids.mjs is also local-only.
*.thumb.jpg
*.thumb.jpg.meta.json

# Machine-local derived-asset byte-size stats, peeled out of the committed
# <asset>.meta.json (see engine/plugins/meta-sidecar.ts). Native encoders
# (msdf-atlas-gen, ffmpeg) aren't byte-reproducible across build hosts, so these
# sizes churn between clones; keeping them local stops that churn. Regenerated on
# every import/build; readMetaSidecar merges them back for the inspector.
*.meta.local.json

# iOS
ios/App/Pods/
ios/App/AppLovinQualityService/
*.xcuserdata/
*.xcworkspacedata
DerivedData/

# Android
android/app/build/
android/build/
android/capacitor-cordova-android-plugins/build/
android/.gradle/
*.apk
*.aab
local.properties

# AppLovin SafeDK (generated by Quality Service plugin)
android/.safedk/

# Platform Tech SDK dist (built from source)
engine/packages/platform-tech/dist/

# SPM build/index cache (large files) — can appear under any package
**/.build/
.spm-cache/
.swiftpm/
Package.resolved

# ── Per-game native build junk (#29) ─────────────────────────────────────────
# Post-#29 native lives under games/<id>/ios|android, NOT the repo root — so the
# anchored `ios/…` + `android/…` rules above are LEGACY pre-#29 paths and do NOT
# cover per-game folders. These games/*/ rules are the real coverage: centralized
# belt-and-suspenders over Capacitor's own generated games/<id>/ios/.gitignore +
# android/.gitignore, so EVERY game excludes build output even if a scaffold's
# generated ignore is stale or missing. Native SOURCE (pbxproj, gradle scripts,
# res/, Info.plist, Package.swift, the vendored plugin .tgz) stays tracked — only
# build artifacts + Capacitor-regenerated config copies are ignored.
# iOS
games/*/ios/App/Pods/
games/*/ios/App/build/
games/*/ios/App/output/
games/*/ios/App/App/public/
games/*/ios/**/xcuserdata/
games/*/ios/capacitor-cordova-ios-plugins/
games/*/ios/App/App/capacitor.config.json
games/*/ios/App/App/config.xml
# Android
games/*/android/**/build/
games/*/android/.gradle/
games/*/android/**/.cxx/
games/*/android/.idea/
games/*/android/capacitor-cordova-android-plugins/
games/*/android/app/src/main/assets/public/
games/*/android/app/src/main/assets/capacitor.config.json
games/*/android/app/src/main/assets/capacitor.plugins.json
games/*/android/app/src/main/res/xml/config.xml

# MCP server build output
engine/tools/game-debug-mcp/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Notarization credentials (App Store Connect API key + the env file that points
# at it). NEVER commit these. Commit .env.notarize.example as the template.
.env.notarize
*.p8
/build/notarize-keys/

# Per-machine settings (device UDIDs, local SDK paths) — never committed. Lives
# next to each game's committed project.config.json. Commit
# project.user.example.json instead.
project.user.json
# Legacy pre-#29 root config (root is not a game post-#29).
/project.config.json

# Logs
*.log
npm-debug.log*
dist/

# E2E model-import scratch (generated assets)
games/*/runtime/assets/__e2e_*__/

# App-icon staging dir — the build copies the source icon here for
# @capacitor/assets; generated icons land in the native projects (committed).
games/*/assets/

# Electron main/preload bundle output
engine/electron/dist/

# Transient engine-plugin build lock (vendorPlugins ensurePluginBuilt — D7)
**/.modoki-building/

# Vendored engine Capacitor-plugin tarballs (capacitor-game-debug, …) are
# CONTENT-ADDRESSED (<name>-<ver>-<hash>.tgz) and COMMITTED so `npm ci` / CI /
# fresh clones consume them with matching lockfile integrity (vendorPlugins.ts).
# They are NOT gitignored — re-vendored only when the plugin content changes.

# electron-builder output
release/

# staged toktx binaries (machine-local, re-staged at build via beforePack)
build/bin/

# Editor working state (panel layouts) — machine-local, per-project, not shared
.modoki/

# Generated by engine/scripts/build-web.mjs (per-game scoped typecheck)
engine/tsconfig.app.scoped.json

# Claude Code local approvals / settings (machine-local, per-worktree)
.claude/settings.local.json

# stray archive of games/ (e.g. for copying a project OUT of the monorepo, #29) — never commit
/games.zip

# modoki-engine.com (site/) — VitePress build + generated reference
site/.vitepress/dist/
site/.vitepress/cache/
site/docs/reference/
site/.vitepress/reference-sidebar.json
