{
  "name": "modoki-engine",
  "private": true,
  "version": "0.2.24",
  "type": "module",
  "description": "Modoki — a Claude-friendly game engine + visual editor",
  "author": "Modoki",
  "main": "engine/electron/dist/main.cjs",
  "workspaces": [
    "engine/packages/*"
  ],
  "scripts": {
    "dev": "vite --config engine/vite.config.ts",
    "build:plugins": "npm run build --workspace engine/packages/capacitor-game-debug --workspace engine/packages/capacitor-litert-lm",
    "postinstall": "npm run build:plugins && node engine/scripts/bootstrap-mcp-deps.mjs && node engine/scripts/bootstrap-game-deps.mjs",
    "electron:build": "node engine/scripts/build-electron.mjs",
    "dev:electron": "npm run electron:build && electron engine/electron/dist/main.cjs",
    "build:editor": "cross-env MODOKI_EDITOR=true vite build --config engine/vite.config.ts",
    "build:electron": "npm run build:editor && npm run electron:build",
    "preview:electron": "npm run electron:build && npm run dev:stop; MODOKI_PROD=1 electron engine/electron/dist/main.cjs",
    "dist": "npm run build:electron && electron-builder --publish never",
    "dist:notarized": "bash engine/scripts/dist-notarized.sh",
    "dist:mac": "npm run build:electron && electron-builder --mac --publish never",
    "dist:win": "npm run build:electron && electron-builder --win --publish never",
    "dist:dir": "npm run build:electron && electron-builder --dir",
    "dev:stop": "bash engine/scripts/stop-dev.sh",
    "clean:texture-cache": "node engine/scripts/clean-texture-cache.mjs",
    "build": "node engine/scripts/build-web.mjs",
    "typecheck": "tsc -b engine && npm --prefix engine/packages/modoki run typecheck && npm --prefix engine/tools/modoki-mcp run typecheck && npm --prefix engine/tools/game-debug-mcp run typecheck",
    "lint": "eslint --config engine/eslint.config.js .",
    "verify": "npm run typecheck && npm run lint && npm test && npm --prefix engine/packages/modoki test",
    "verify:all": "npm run verify && npm run test:e2e",
    "verify:packaged": "npm run verify && npm run smoke:packaged",
    "hooks:install": "node engine/scripts/install-git-hooks.mjs",
    "prepare": "node engine/scripts/install-git-hooks.mjs",
    "preview": "vite preview --config engine/vite.config.ts",
    "test": "vitest run --config engine/vite.config.ts",
    "test:watch": "vitest --config engine/vite.config.ts",
    "test:framework": "vitest run --config engine/vite.config.ts engine/tests/framework",
    "test:game": "vitest run --config engine/vite.config.ts engine/tests/game",
    "test:e2e": "playwright test --config engine/playwright.config.ts",
    "test:packaged": "bash engine/scripts/test-packaged.sh",
    "smoke:packaged": "bash engine/scripts/smoke-packaged.sh",
    "smoke:playable": "node engine/scripts/smoke-playable.mjs",
    "smoke:mcp": "npm --prefix engine/tools/modoki-mcp run smoke",
    "editor": "bash engine/scripts/relaunch-editor.sh",
    "editor:main": "MODOKI_BACKEND_PORT=5179 bash engine/scripts/launch-editor.sh games/3d-test",
    "editor:ai": "MODOKI_BACKEND_PORT=5180 bash engine/scripts/launch-editor.sh games/3d-test",
    "editor:main:packaged": "MODOKI_BACKEND_PORT=5179 bash engine/scripts/test-packaged.sh games/3d-test",
    "editor:ai:packaged": "MODOKI_BACKEND_PORT=5180 bash engine/scripts/test-packaged.sh games/3d-test"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@modoki/engine": "file:engine/packages/modoki",
    "@monogrid/gainmap-js": "^3.4.0",
    "@pixi/react": "^8.0.5",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@zappar/msdf-generator": "^1.2.4",
    "capacitor-game-debug": "file:engine/packages/capacitor-game-debug",
    "capacitor-litert-lm": "file:engine/packages/capacitor-litert-lm",
    "chess.js": "^1.4.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "flexlayout-react": "^0.8.19",
    "koota": "^0.6.5",
    "maxrects-packer": "^2.7.3",
    "meshoptimizer": "^1.0.1",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "three": "^0.184.0",
    "vite": "^8.0.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.4",
    "@gltf-transform/cli": "^4.3.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "4.60.1",
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@rollup/rollup-win32-x64-msvc": "4.60.1",
    "canvas": "^3.2.3",
    "fsevents": "^2.3.3"
  }
}
