# Notarization credentials — App Store Connect API key path.
#
# Copy this file to `.env.notarize` (gitignored) and fill in your values, then
# build with:  npm run dist:notarized
#
# This replaces the app-specific-password path (APPLE_ID + APPLE_APP_SPECIFIC_
# PASSWORD + APPLE_TEAM_ID). The API key never expires on a schedule, can be
# revoked independently, and — unlike a password on the command line — is read
# from this gitignored file so no secret lands in your shell history or the
# process list.
#
# How to get the key (one-time):
#   1. https://appstoreconnect.apple.com → Users and Access → Integrations →
#      App Store Connect API → "+" to generate a key.
#      Role "Developer" is sufficient for notarization.
#   2. Download the AuthKey_XXXXXXXXXX.p8 (DOWNLOAD ONCE — Apple won't show it
#      again). Put it at build/notarize-keys/AuthKey_XXXXXXXXXX.p8 (gitignored).
#   3. Note the Key ID (the XXXXXXXXXX) and the Issuer ID (UUID shown above the
#      key list).

# Absolute or repo-relative path to the .p8 private key file.
APPLE_API_KEY=build/notarize-keys/AuthKey_XXXXXXXXXX.p8
# The Key ID (10 chars, also embedded in the .p8 filename).
APPLE_API_KEY_ID=XXXXXXXXXX
# The Issuer ID (UUID) from the top of the API Keys page.
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
