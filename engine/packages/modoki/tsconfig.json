{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "koota": ["../../node_modules/koota"],
      "three": ["../../node_modules/three"],
      "three/*": ["../../node_modules/three/*"],
      "@types/three": ["../../node_modules/@types/three"],
      "react": ["../../node_modules/react"],
      "react/*": ["../../node_modules/react/*"],
      "zustand": ["../../node_modules/zustand"],
      "zustand/*": ["../../node_modules/zustand/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["tests", "dist"]
}
