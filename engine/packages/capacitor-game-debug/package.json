{
  "name": "capacitor-game-debug",
  "version": "1.0.0",
  "description": "Capacitor plugin for native game debug bridge — TCP server + UDP auto-discovery",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "CapacitorGameDebug.podspec",
    "Package.swift"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    }
  }
}
